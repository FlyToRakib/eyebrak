{
  "manifest_version": 3,
  "name": "DeepCycle - Focus Timer & Wellness Assistant",
  "short_name": "DeepCycle",
  "version": "2.1.1",
  "description": "Boost productivity with Pomodoro timers, site blocking, health breaks, and gamified focus tracking. The ultimate wellness assistant.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scripts/content.js"
      ],
      "css": [
        "scripts/content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/blocked.html",
        "pages/blocked.js",
        "scripts/offscreen.html",
        "sounds/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open DeepCycle"
    },
    "start-pomodoro": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Start/Pause Pomodoro Timer"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}